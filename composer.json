{
    "name": "branson/restaurants",
    "description": "Branson restaurants",
    "keywords": ["branson", "restaurants"],
    "homepage": "https://thevacationchannel.com/",
    "type": "project",
    "license": "BSD-3-Clause",
    "minimum-stability": "dev",
	"prefer-stable" : true,
    "require": {
        "php": ">=8.2.0",
        "yiisoft/yii2": "^2.0.54",
        "yiisoft/yii2-bootstrap5": "*",
        "yiisoft/yii2-symfonymailer": "^2.0",
        "yiisoft/yii2-jui": "^2.0.7",
        "webvimark/module-user-management": "^1.0.13",
        "dmstr/yii2-adminlte-asset": "^2.6.2",
        "yiisoft/yii2-authclient": "^2.2.17",
        "himiklab/yii2-recaptcha-widget" : "^2.1.1",
        "yiisoft/yii2-imagine": "*",
        "mihaildev/yii2-ckeditor": "^1.0",
        "mihaildev/yii2-elfinder": "^1.4",
        "ext-dom": "*",
        "ext-libxml": "*",
        "ext-fileinfo": "*",
        "ext-curl": "*",
        "guzzlehttp/guzzle" : "*",
        "ext-json": "*",
        "dmstr/yii2-cookie-consent": "^1.4"
    },
    "require-dev": {
        "yiisoft/yii2-debug": "*",
        "yiisoft/yii2-gii": "*"
    },
    "config": {
        "process-timeout": 1800,
        "optimize-autoloader": true,
        "fxp-asset": {
            "enabled": "false"
        },
        "platform": {
            "php": "8.2"
        },
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "composer/installers": true
        }
    },
    "extra": {
        "installer-types": ["npm-asset", "bower-asset"],
        "asset-installer-paths": {
            "npm-asset-library": "vendor/npm-asset",
            "bower-asset-library": "vendor/bower-asset"
        }
    },
    "autoload": {
        "classmap": [
            "common/models/source"
        ]
    },
    "repositories": {
        "asset-packagist": {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    }
}
